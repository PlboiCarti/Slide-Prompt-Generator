# ==================== Môi trường ====================
# development hoặc production. Production bắt buộc đổi JWT_SECRET_KEY.
ENVIRONMENT=development

# ==================== Database ====================
# SQLite mặc định, không cần chỉnh khi dev.
# Đổi sang Postgres khi cần: postgresql://user:pass@host:5432/dbname
SQLALCHEMY_DATABASE_URL=sqlite:///./database.db

# ==================== Gemini API ====================
# Lấy API key tại https://aistudio.google.com/app/apikey
gemini_api_key=your_gemini_api_key
llm_model=gemini-2.5-flash
min_slides_limit=3
max_slides_limit=30

# ==================== JWT ====================
# QUAN TRỌNG: đổi sang chuỗi ngẫu nhiên >= 32 ký tự ở production.
# Tạo bằng:
#   - Linux/Mac:  openssl rand -hex 32
#   - Python:     python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev_only_secret_key_change_in_production_2025
JWT_ALGORITHM=HS256
# Thời hạn access token, tính bằng phút (1440 = 1 ngày)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== Google OAuth ====================
# Lấy từ https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ==================== Frontend / CORS ====================
FRONTEND_URL=http://localhost:3000
# Danh sách origin được phép gọi API, phân tách bằng dấu phẩy
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== Backend base URL ====================
# Dùng để build link trong email xác thực
BASE_URL=http://localhost:8000

# ==================== Rate limiting — đăng nhập ====================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ==================== Rate limiting — tạo prompt ====================
MAX_GENERATE_ATTEMPTS=5
GENERATE_LOCKOUT_MINUTES=10

# ==================== Email verification ====================
# Thời hạn link xác thực email (giờ)
EMAIL_VERIFY_TTL_HOURS=24

# Rate limit cho nút "Gửi lại email xác thực" (theo email)
MAX_RESEND_ATTEMPTS=5
RESEND_LOCKOUT_MINUTES=10

# Rate limit cho polling GET /auth/verification-status (theo IP)
MAX_VERIFICATION_STATUS_ATTEMPTS=60
VERIFICATION_STATUS_LOCKOUT_MINUTES=1

# ==================== SMTP (gửi email xác thực) ====================
# Để trống SMTP_USER/SMTP_PASSWORD => dev mode, link verify được log ra
# console thay vì gửi email thật.
# Gmail: bật 2FA rồi tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Prompt Builder

# ==================== OCR (Tesseract / Poppler) ====================
# Chỉ cần khai báo nếu Tesseract/Poppler KHÔNG nằm trong PATH (thường gặp
# trên Windows). Để trống nếu đã thêm vào PATH hoặc dùng Linux/Docker.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\poppler\Library\bin
TESSERACT_CMD=
POPPLER_PATH=
