# ==================== ENVIRONMENT ====================
# development | production
ENVIRONMENT=development

# ==================== GEMINI LLM ====================
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model config
LLM_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/text-embedding-004

MIN_SLIDES_LIMIT=3
MAX_SLIDES_LIMIT=30

# ==================== DATABASE ====================
SQLALCHEMY_DATABASE_URL=sqlite:///./database.db

# ==================== AUTH - JWT ====================
# QUAN TRỌNG: Tạo random string thật, KHÔNG dùng giá trị mẫu này
# Cách tạo:
#   - Linux/Mac:   openssl rand -hex 32
#   - Python:      python -c "import secrets; print(secrets.token_hex(32))"
#   - Online:      https://generate-secret.vercel.app/32
JWT_SECRET_KEY=dev_only_secret_key_change_in_production_2025
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== AUTH - GOOGLE OAUTH ====================
# Lấy từ: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ==================== FRONTEND / CORS ====================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== BACKEND BASE URL ====================
# Dùng cho các link trong email (verify, reset password...)
BASE_URL=http://localhost:8000

# ==================== AUTH - RATE LIMITING ====================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

MAX_GENERATE_ATTEMPTS=5
GENERATE_LOCKOUT_MINUTES=10

# ==================== EMAIL VERIFICATION ====================
EMAIL_VERIFY_TTL_HOURS=24

# Rate limit cho nút "Gửi lại email xác thực" (theo email)
MAX_RESEND_ATTEMPTS=5
RESEND_LOCKOUT_MINUTES=10

# Rate limit cho polling GET /auth/verification-status (theo IP)
MAX_VERIFICATION_STATUS_ATTEMPTS=60
VERIFICATION_STATUS_LOCKOUT_MINUTES=1

# ==================== SMTP (để gửi email verify) ====================
# Để trống nếu chưa cần test gửi email.
# Khi để trống, link verify sẽ in ra console (xem code register_with_email).
# Gmail: dùng App Password, không dùng password thường.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Prompt Builder

# ==================== OCR (Tesseract/Poppler) ====================
# Chỉ cần khai báo nếu Tesseract/Poppler KHÔNG nằm trong PATH (thường gặp
# trên Windows). Để trống nếu đã thêm vào PATH hoặc dùng Linux/Docker.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# POPPLER_PATH=C:\poppler\Library\bin
TESSERACT_CMD=
POPPLER_PATH=
